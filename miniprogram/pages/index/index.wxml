<!--pages/index/index.wxml-->
<view class="container pb-20">
  <!-- Access Control Mask -->
  <view wx:if="{{ !isUserReady }}" class="full-screen-mask bg-white flex-center">
     <van-loading type="spinner" vertical>身份校验中...</van-loading>
  </view>
  <view wx:else>

  <!-- 顶部搜索 (吸顶) -->
  <view class="sticky-top z-index-10 search-transparent">
     <van-search
        value="{{ homeSearchVal }}"
        placeholder="产品代码/物料名称/标签编号/批号/供应商/库位"
        shape="round"
        bind:search="onSearch"
        bind:change="onSearchChange"
        bind:clear="onSearchClear"
        custom-class="search-compact"
     />
  </view>

  <view class="p-20">
    <!-- 扫码领料 (主操作 - 紧凑版) -->
    <view class="scan-card bg-primary text-white p-20 shadow-lg relative rounded-xl overflow-hidden mb-15" bindtap="onScanWithdraw">
       <view class="circle-bg"></view>
       <view class="flex-row items-center justify-between z-relative">
          <view>
             <view class="text-xl font-bold mb-5">智能扫码</view>
             <view class="text-xs opacity-80">入库 / 领料 / 查询</view>
          </view>
          <van-icon name="scan" size="32px" />
       </view>
    </view>

    <!-- 快捷领料 (独立辅助入口 - 按钮样式) -->
    <view class="mb-15">
      <view class="btn-retrieve" bindtap="onShowMaterialSelect" hover-class="btn-hover">
        <van-icon name="search" class="mr-5" size="18px" /> 快捷领料
      </view>
    </view>

    <!-- 统计数据 (2x2 网格 - 加高版) -->
    <view class="mb-25">
      <view class="text-md font-bold mb-10 text-dark">实时数据</view>
      <van-row gutter="15">
        <van-col span="12">
          <view class="stat-card bg-blue-light p-20 mb-15 text-center active-opacity" bindtap="onStatTotal">
            <view class="text-4xl font-bold">{{ stats.totalMaterials }}</view>
            <view class="text-xs opacity-70 mt-5">总物料</view>
          </view>
        </van-col>
        <van-col span="12">
          <view class="stat-card bg-warning-light p-20 mb-15 text-center active-opacity" bindtap="onStatWarning">
            <view class="text-4xl font-bold">{{ stats.lowStock }}</view>
            <view class="text-xs opacity-70 mt-5">预警</view>
          </view>
        </van-col>
        <van-col span="12">
          <view class="stat-card bg-green-light p-20 text-center active-opacity" bindtap="onStatTodayIn">
            <view class="text-4xl font-bold">{{ stats.todayIn }}</view>
            <view class="text-xs opacity-70 mt-5">今日入库</view>
          </view>
        </van-col>
        <van-col span="12">
          <view class="stat-card bg-purple-light p-20 text-center active-opacity" bindtap="onStatTodayOut">
            <view class="text-4xl font-bold">{{ stats.todayOut }}</view>
            <view class="text-xs opacity-70 mt-5">今日出库</view>
          </view>
        </van-col>
      </van-row>
    </view>

    <!-- 快捷入口列表 -->
    <van-cell-group inset custom-class="shadow-sm">
      <van-cell title="新增物料" icon="add-o" is-link url="/pages/material-add/index" />
      <van-cell title="库存查询" icon="search" is-link url="/pages/inventory/index" />
      <van-cell title="物料查询" icon="bookmark-o" is-link url="/pages/material-directory/index" />
      <van-cell title="人员与权限" icon="manager-o" is-link url="/pages/super-admin/user-manage/index" wx:if="{{ isSuperAdmin }}" />
      <van-cell title="审批中心" icon="todo-list-o" is-link url="/pages/admin/approval-center/index" wx:if="{{ isAdmin }}" />
      <van-cell title="物料管理" icon="goods-collect-o" is-link url="/pages/admin/material-list" wx:if="{{ isAdmin }}" />
      <van-cell title="审计日志" icon="shield-o" is-link url="/pages/admin-logs/index" wx:if="{{ isAdmin }}" />
      <van-cell title="操作日志" icon="orders-o" is-link url="/pages/logs/index" />
    </van-cell-group>
  </view>





  <van-toast id="van-toast" />
  <van-dialog id="van-dialog" />

  <!-- 2. Select Popup (Unified Home Design) -->
  <van-popup
    show="{{ showSelectPopup }}"
    position="bottom"
    round
    custom-style="height: 85%; background-color: #F7F8FA;"
    bind:close="onCloseSelectPopup"
  >
    <view class="flex-col h-full bg-page">
       <view class="bg-white sticky-top z-index-100">
           <!-- 使用公共组件 popup-header -->
           <popup-header title="快捷领料" bind:close="onCloseSelectPopup" />

           <van-tabs
              id="mode-tabs"
              active="{{ quickWithdrawMode }}"
              bind:change="onQuickWithdrawModeChange"
              color="#2C68FF"
              line-width="56px"
              border="{{ false }}"
           >
               <van-tab title="按产品代码领料" name="product"></van-tab>
               <van-tab title="按批次领料" name="batch"></van-tab>
           </van-tabs>

           <view class="px-safe pb-5">
              <van-search
                 value="{{ selectSearchVal }}"
                 placeholder="产品代码/物料名称/标签编号/批号/供应商/库位"
                 shape="round"
                 background="#fff"
                 bind:search="onSelectSearch"
                 bind:change="onSelectSearchChange"
                 bind:clear="onSelectSearchClear"
                 custom-class="search-compact"
              />
           </view>

           <van-tabs
              id="category-tabs"
              active="{{ selectActiveTab }}"
              bind:change="onSelectTabChange"
              color="#2C68FF"
              line-width="30px"
              border="{{ false }}"
           >
               <van-tab title="化材" name="chemical"></van-tab>
               <van-tab title="膜材" name="film"></van-tab>
           </van-tabs>
       </view>

       <scroll-view scroll-y style="flex: 1; height: 1px;" enable-back-to-top bindscrolltolower="onSelectPopupReachBottom">
           <view class="px-safe pt-safe pb-safe">
               <!-- 使用统一列表项组件 -->
               <material-list-item
                   wx:for="{{ selectList }}"
                   wx:key="_id"
                   item="{{ item }}"
                   showCategory="{{ false }}"
                   showArrow="{{ false }}"
                   bind:tap="onSelectAggregatedItem"
                   data-item="{{ item }}"
               />

              <view wx:if="{{ selectLoading && selectList.length === 0 }}" class="page-loading-state">
                <van-loading size="24px" vertical>搜索中...</van-loading>
              </view>
              <van-empty wx:if="{{ !selectLoading && selectList.length === 0 }}" description="暂无匹配库存" />
              <view wx:if="{{ selectLoading && selectList.length > 0 }}" class="text-center p-10">
                <van-loading size="20px">加载中...</van-loading>
              </view>
              <view wx:if="{{ selectIsEnd && selectList.length > 0 }}" class="list-end-state">
                已无更多
              </view>
              <view style="height: 40px;"></view>
           </view>
       </scroll-view>
    </view>
  </van-popup>

  <!-- 3. Batch Selection Popup (Unified Home Design) -->
  <van-popup
    show="{{ showBatchPopup }}"
    position="bottom"
    round
    custom-style="height: 70%; background-color: #F7F8FA;"
    bind:close="onCloseBatchPopup"
    z-index="1100"
  >
       <view class="flex-col h-full bg-page">
           <view class="bg-white sticky-top z-index-100">
               <!-- 使用公共组件 popup-header -->
               <popup-header title="选择批次" bind:close="onCloseBatchPopup" />
               <view class="px-safe pb-10">
                   <view class="context-bar-home">
                       <view class="context-summary">
                          <text class="context-caption">产品代码</text>
                          <text class="context-code">{{ selectedAggItem.product_code }}</text>
                       </view>
                   </view>
               </view>
           </view>

           <scroll-view scroll-y style="flex: 1; height: 1px;">
                <view class="px-safe pt-safe pb-safe">
                    <batch-list-item
                        wx:for="{{ batchList }}"
                        wx:key="batch_number"
                        item="{{ item }}"
                        bind:itemtap="onSelectBatchItem"
                        data-batch="{{ item }}"
                    />
                    <view style="height: 40px;"></view>
                </view>
            </scroll-view>
       </view>
  </van-popup>

  <!-- 5. 领料弹窗 (Component) -->
  <withdraw-dialog
    show="{{ showWithdrawDialog }}"
    item="{{ withdrawItem }}"
    mode="{{ withdrawMode }}"
    recommendedCode="{{ recommendedCode }}"
    bind:close="onWithdrawClose"
    bind:confirm="onWithdrawConfirmFn"
  />
  </view>
</view>
