.zone-page {
  min-height: 100vh;
  background: #f7f8fa;
  padding: 24rpx;
  box-sizing: border-box;
}

.zone-header {
  display: flex;
  flex-direction: column;
  gap: 16rpx;
  margin-bottom: 20rpx;
  padding: 28rpx 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.zone-toolbar__title {
  font-size: 36rpx;
  font-weight: 600;
  color: #111827;
}

.zone-toolbar__hint {
  font-size: 24rpx;
  line-height: 1.6;
  color: #64748b;
}

.zone-hint {
  margin-bottom: 24rpx;
  padding: 20rpx 24rpx;
  border-radius: 20rpx;
  background: #eef4ff;
  color: #475569;
  font-size: 24rpx;
  line-height: 1.6;
}

.zone-loading {
  padding: 120rpx 0;
  display: flex;
  justify-content: center;
}

.zone-list {
  display: flex;
  flex-direction: column;
  gap: 20rpx;
}

.zone-card {
  padding: 24rpx;
  border-radius: 24rpx;
  background: #ffffff;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.06);
}

.zone-card--disabled {
  opacity: 0.7;
}

.zone-card__main {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.zone-card__name {
  font-size: 32rpx;
  font-weight: 600;
  color: #111827;
}

.zone-card__meta {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
}

.zone-card__scope {
  font-size: 24rpx;
  color: #64748b;
}

.zone-card__actions {
  display: flex;
  align-items: center;
  gap: 12rpx;
  flex-wrap: wrap;
  margin-top: 24rpx;
}
