@import "../../../app.wxss";

.container {
  min-height: 100vh;
  padding: 16px;
  padding-bottom: 112px;
  background: var(--color-bg-page);
  box-sizing: border-box;
}

.sticky-panel {
  position: sticky;
  top: 0;
  z-index: 10;
  background: var(--color-bg-page);
  padding-bottom: 12px;
}

.template-panel {
  background: #fff;
  border-radius: 16px;
  box-shadow: var(--shadow-sm);
  margin-bottom: 12px;
  overflow: hidden;
}

.template-panel__title {
  padding: 14px 16px 6px;
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
}

.selection-brief {
  padding: 0 6px;
  font-size: 12px;
  color: var(--color-text-secondary);
}

.selection-tip {
  padding: 6px 6px 0;
  font-size: 12px;
  color: var(--color-text-secondary);
}

.inline-refresh-state {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 16rpx 0 24rpx;
}

.label-export-row {
  display: flex;
  align-items: flex-start;
  gap: 12px;
  padding: 14px 16px;
  margin-bottom: 12px;
  background: #fff;
  border: 1px solid rgba(226, 232, 240, 0.9);
  border-radius: 16px;
  box-shadow: var(--shadow-sm);
}

.label-export-row.is-selected {
  border-color: rgba(44, 104, 255, 0.32);
  box-shadow: 0 8px 18px rgba(44, 104, 255, 0.08);
}

.label-export-row__selector {
  width: 22px;
  height: 22px;
  flex-shrink: 0;
  margin-top: 2px;
  border-radius: 50%;
  border: 1.5px solid #CBD5E1;
  color: transparent;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  font-weight: 700;
  box-sizing: border-box;
}

.label-export-row__selector.is-selected {
  background: var(--color-brand);
  border-color: var(--color-brand);
  color: #fff;
}

.label-export-row__content {
  flex: 1;
  min-width: 0;
}

.label-export-row__title {
  display: flex;
  align-items: baseline;
  justify-content: space-between;
  gap: 12px;
}

.label-export-row__code {
  font-family: var(--font-mono);
  font-size: 16px;
  font-weight: 700;
  color: var(--color-brand);
}

.label-export-row__product {
  font-family: var(--font-mono);
  font-size: 14px;
  font-weight: 600;
  color: var(--color-text-primary);
  flex-shrink: 0;
}

.label-export-row__name {
  margin-top: 6px;
  font-size: 14px;
  font-weight: 500;
  color: var(--color-text-primary);
  line-height: 1.45;
}

.label-export-row__meta {
  margin-top: 6px;
  font-size: 12px;
  color: var(--color-text-secondary);
}

.footer-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(255, 255, 255, 0.96);
  backdrop-filter: blur(8px);
  box-shadow: 0 -6px 18px rgba(15, 23, 42, 0.06);
  padding: 12px 16px calc(12px + env(safe-area-inset-bottom));
}

.footer-bar__hint {
  margin-bottom: 10px;
  font-size: 12px;
  color: var(--color-text-secondary);
}

.footer-bar__button {
  height: 44px;
  border-radius: 999px;
  background: var(--color-brand);
  color: #fff;
  font-size: 15px;
  font-weight: 600;
  display: flex;
  align-items: center;
  justify-content: center;
}

.footer-bar__button.is-disabled {
  background: #C8D2E6;
  color: rgba(255, 255, 255, 0.92);
}
