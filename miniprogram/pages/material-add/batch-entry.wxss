/* pages/material-add/batch-entry.wxss */
page {
  background-color: var(--color-bg-page);
}

.pb-100 {
  padding-bottom: 150rpx;
}

.bg-white { background-color: #fff; }
.rounded-md { border-radius: 12rpx; }
.text-center { text-align: center; }
.text-xs { font-size: 24rpx; }
.text-sm { font-size: 28rpx; }
.text-base { font-size: 32rpx; }
.font-bold { font-weight: bold; }
.text-secondary { color: #969799; }
.text-primary { color: var(--color-primary); }
.bg-danger { background-color: #ee0a24; }
.text-white { color: #fff; }

.p-3 { padding: 24rpx; }
.p-4 { padding: 32rpx; }
.mb-2 { margin-bottom: 16rpx; }
.mb-3 { margin-bottom: 24rpx; }
.mt-2 { margin-top: 16rpx; }
.mt-3 { margin-top: 24rpx; }
.ml-2 { margin-left: 16rpx; }
.ml-3 { margin-left: 24rpx; }
.mr-2 { margin-right: 16rpx; }
.px-3 { padding-left: 24rpx; padding-right: 24rpx; }

.flex-row { display: flex; flex-direction: row; }
.flex-1 { flex: 1; }
.items-center { align-items: center; }
.justify-between { justify-content: space-between; }
.block { display: block; }

.h-full { height: 100%; }
.flex-center { display: flex; justify-content: center; align-items: center; }

.border-b { border-bottom: 1rpx solid #f5f6f7; }

.fixed-bottom {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  z-index: 100;
}

.shadow-top {
  box-shadow: 0 -4rpx 16rpx rgba(0,0,0,0.05);
}

.safe-area-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

.zone-manage-entry {
  display: flex;
  justify-content: flex-end;
  padding: 8px 32rpx 12rpx;
}

.zone-manage-link {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--color-primary);
}

.validity-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 32rpx;
}

.validity-switch-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
}

.material-template-card {
  border-radius: 24rpx;
  box-shadow: 0 8rpx 24rpx rgba(15, 23, 42, 0.05);
}

.section-title {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-secondary);
  margin-bottom: 20rpx;
}

.template-head {
  margin-bottom: 8rpx;
}

.template-code,
.suggestion-code {
  font-size: 34rpx;
  line-height: 1.2;
  font-weight: 700;
  color: var(--color-brand);
  margin-right: 12rpx;
}

.template-chip {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  line-height: 1.4;
  color: #475569;
  background: #F1F5F9;
}

.template-name,
.suggestion-name {
  font-size: 30rpx;
  line-height: 1.45;
  color: var(--color-text-primary);
}

.template-meta {
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.entry-refill-badge {
  padding: 4rpx 12rpx;
  border-radius: 999rpx;
  background: rgba(37, 99, 235, 0.12);
  color: #1D4ED8;
  font-size: 22rpx;
  line-height: 1.3;
  font-weight: 600;
}

.entry-notice {
  padding: 10rpx 14rpx;
  border-radius: 16rpx;
  font-size: 22rpx;
  line-height: 1.6;
  word-break: break-word;
}

.entry-notice--refill {
  background: rgba(37, 99, 235, 0.08);
  color: #1D4ED8;
}

.spec-hint-text {
  color: #2563EB;
}

.template-change-btn {
  margin-top: 24rpx;
}

.suggestion-box {
  margin-top: 16rpx;
  border: 1rpx solid #E5E7EB;
  border-radius: 20rpx;
  overflow: hidden;
  background: #fff;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #F3F4F6;
}

.suggestion-item:last-child {
  border-bottom: none;
}

.suggestion-meta {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.code-picker-block {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.code-picker-label {
  font-size: 26rpx;
  font-weight: 600;
  color: var(--color-text-primary);
}

.code-picker-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.code-prefix-chip {
  flex-shrink: 0;
  min-width: 88rpx;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #EFF6FF;
  color: var(--color-brand);
  font-size: 28rpx;
  font-weight: 700;
  display: flex;
  align-items: center;
  justify-content: center;
}

.code-number-input {
  flex: 1;
  min-width: 0;
  height: 64rpx;
  padding: 0 20rpx;
  border-radius: 18rpx;
  background: #F8FAFC;
  border: 1rpx solid #E2E8F0;
  color: var(--color-text-primary);
  font-size: 28rpx;
  line-height: 64rpx;
  box-sizing: border-box;
}

.code-query-btn {
  flex-shrink: 0;
  min-width: 112rpx !important;
  height: 64rpx !important;
  padding: 0 20rpx !important;
  border-radius: 18rpx !important;
  font-size: 24rpx !important;
}

.code-picker-hint {
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.spec-submit-btn {
  margin-top: 20rpx;
}
