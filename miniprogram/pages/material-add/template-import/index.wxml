<view class="container">
  <view class="bg-indigo-50 p-20 rounded-lg mb-20 mx-20 mt-20">
    <view class="flex-row items-center mb-12">
      <van-icon name="description" color="#4F46E5" size="18px" class="mr-8" />
      <view class="text-base font-bold text-primary">模板导入入库</view>
      <view class="import-scene-badge ml-8">化材 / 膜材通用</view>
    </view>
    <view class="text-sm text-secondary leading-loose">
      <view>1. 请先导出系统当前的<text class="font-bold text-main">最新模板（.xlsx）</text></view>
      <view>2. 按模板填写后，<text class="font-bold text-main">直接上传 .xlsx</text></view>
      <view>3. 仅支持上传系统导出的<text class="font-bold text-main">.xlsx</text>模板文件</view>
      <view>4. 一行对应一个标签编号，不支持未知产品代码直接入库</view>
    </view>
  </view>

  <view class="px-20">
    <view class="bg-white p-20 rounded-lg mb-16 shadow-sm" bind:tap="onExportLatestTemplate">
      <view class="flex-row items-center mb-8">
        <view class="w-40 h-40 rounded-full flex-center bg-indigo-50 mr-12">
          <van-icon name="description" size="20px" color="#4F46E5" />
        </view>
        <view class="flex-1">
          <view class="text-base font-bold text-main">第一步：导出最新模板</view>
          <view class="text-xs text-secondary mt-4">{{ exportingTemplate ? '正在生成并下载库存入库模板...' : '获取带下拉、校验和说明页的正式模板（.xlsx）' }}</view>
        </view>
        <van-icon name="arrow" color="#C8C9CC" />
      </view>
    </view>

    <view class="bg-white p-20 rounded-lg shadow-sm" bind:tap="onChooseFile">
      <view class="flex-row items-center mb-8">
        <view class="w-40 h-40 rounded-full flex-center bg-emerald-50 mr-12">
          <van-icon name="add-o" size="20px" color="#10B981" />
        </view>
        <view class="flex-1">
          <view class="text-base font-bold text-main">第二步：上传文件</view>
          <view class="text-xs text-secondary mt-4">{{ selectedFile ? selectedFile.name : '选择填写完成的 .xlsx 文件预览并导入' }}</view>
        </view>
        <van-icon name="arrow" color="#C8C9CC" />
      </view>
    </view>
  </view>

  <view wx:if="{{ parsing }}" class="parsing-card">
    <van-loading size="24px" />
    <text class="ml-12">正在解析文件...</text>
  </view>

  <view wx:if="{{ previewData.length > 0 }}" class="preview-section">
    <view class="section-header">
      <text class="section-title">预览结果</text>
      <text class="section-count">共 {{ previewData.length }} 条</text>
    </view>

    <view class="stats-row">
      <view class="stat-item success">
        <text class="stat-num">{{ validCount }}</text>
        <text class="stat-label">有效</text>
      </view>
      <view class="stat-item refill" wx:if="{{ refillCount > 0 }}">
        <text class="stat-num">{{ refillCount }}</text>
        <text class="stat-label">待补料</text>
      </view>
      <view class="stat-item info" wx:if="{{ createCount > 0 }}">
        <text class="stat-num">{{ createCount }}</text>
        <text class="stat-label">新增</text>
      </view>
      <view class="stat-item error" wx:if="{{ errorCount > 0 }}">
        <text class="stat-num">{{ errorCount }}</text>
        <text class="stat-label">错误</text>
      </view>
      <view class="stat-item warning" wx:if="{{ warningCount > 0 }}">
        <text class="stat-num">{{ warningCount }}</text>
        <text class="stat-label">提醒</text>
      </view>
    </view>

    <view class="preview-list">
      <view
        wx:for="{{ previewData }}"
        wx:key="previewKey"
        class="preview-item {{ item.hasError ? 'has-error' : '' }} {{ item.submit_action === 'refill' && !item.hasError ? 'has-refill' : '' }}"
      >
        <view class="preview-row">
          <view class="preview-row-main">
            <text class="preview-code">{{ item.unique_code }}</text>
            <van-tag type="{{ item.category === 'chemical' ? 'primary' : 'success' }}" plain>
              {{ item.category === 'chemical' ? '化材' : '膜材' }}
            </van-tag>
          </view>
          <view wx:if="{{ item.submit_action === 'refill' && !item.hasError }}" class="preview-status-badge">
            待补料
          </view>
        </view>
        <view class="preview-name">物料名称：{{ item.material_name || '--' }}</view>
        <view class="preview-meta">产品代码：{{ item.product_code || '--' }}</view>
        <view class="preview-meta">子类别：{{ item.sub_category || '--' }}</view>
        <view class="preview-meta">批号：{{ item.batch_number || '--' }}</view>
        <view class="preview-meta">库位：{{ item.location || '--' }}</view>
        <view class="preview-meta">数量摘要：{{ item.quantity_summary || '--' }}</view>
        <view
          wx:if="{{ item.noticeText }}"
          class="preview-notice {{ item.noticeType === 'error' ? 'preview-notice--error' : (item.noticeType === 'refill' ? 'preview-notice--refill' : 'preview-notice--warning') }}"
        >
          <van-icon
            name="{{ item.noticeType === 'error' ? 'warning-o' : 'info-o' }}"
            size="13px"
            class="preview-notice-icon"
          />
          <text class="preview-notice-text">{{ item.noticeText }}</text>
        </view>
      </view>
    </view>
  </view>

<van-empty
    wx:if="{{ !selectedFile && !parsing }}"
    image="search"
    description="请先导出模板并上传 .xlsx 文件"
    custom-class="mt-40"
  />
</view>

<view wx:if="{{ previewData.length > 0 }}" class="footer-bar safe-area-bottom">
  <van-button
    type="primary"
    block
    round
    size="large"
    loading="{{ importing }}"
    disabled="{{ importing || validCount === 0 }}"
    bind:click="onImport"
  >
    确认入库 ({{ validCount }} 条)
  </van-button>
</view>

<van-toast id="van-toast" />
<van-dialog id="van-dialog" />
