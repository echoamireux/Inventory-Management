/* pages/material-add/index.wxss */
/* 注意：通用样式已移至 app.wxss，此文件仅保留页面特有样式 */

.container {
  padding-bottom: 50px;
  background-color: var(--color-bg-page);
  min-height: 100vh;
}

.top-action-bar {
  display: flex;
  align-items: center;
}

.template-entry-card {
  padding: 24rpx 28rpx;
  border-radius: 24rpx;
  background: linear-gradient(135deg, rgba(44, 104, 255, 0.08) 0%, rgba(255, 255, 255, 0.96) 100%);
  border: 1px solid rgba(44, 104, 255, 0.12);
  box-shadow: var(--shadow-sm);
}

.template-entry-card__header {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 24rpx;
}

.template-entry-card__title {
  font-size: 30rpx;
  line-height: 1.4;
  font-weight: 700;
  color: var(--color-text-primary);
}

.template-entry-card__desc {
  margin-top: 10rpx;
  font-size: 24rpx;
  line-height: 1.6;
  color: var(--color-text-secondary);
}

.template-entry-card__badge {
  flex-shrink: 0;
  padding: 10rpx 18rpx;
  border-radius: 999rpx;
  background: rgba(44, 104, 255, 0.1);
  color: var(--color-brand);
  font-size: 22rpx;
  line-height: 1;
  font-weight: 600;
}

.top-action-bar__item {
  min-width: 0;
}

.top-action-bar--dual {
  justify-content: space-between;
}

.top-action-bar--dual .top-action-bar__item {
  flex: 1;
}

.top-action-bar--dual .top-action-bar__item + .top-action-bar__item {
  margin-left: 10px;
}

.top-action-bar--single {
  justify-content: center;
}

.top-action-bar--single .top-action-bar__item--primary {
  flex: none;
  width: calc((100% - 10px) / 2);
  min-width: 280rpx;
  max-width: 420rpx;
}

/* 扫码按钮 */
.scan-btn {
  width: 64px !important;
  padding: 0 !important;
  height: 30px !important;
  line-height: 28px !important;
  text-align: center !important;
  font-size: 13px !important;
  margin-left: 8px;
}

.label-code-field {
  padding: 20rpx 32rpx 24rpx;
}

.label-code-main-row {
  display: flex;
  align-items: center;
}

.label-code-label-wrap {
  width: 168rpx;
  flex-shrink: 0;
  display: flex;
  align-items: center;
  padding-right: 16rpx;
}

.label-code-required {
  margin-left: 8rpx;
  color: var(--color-danger, #ee0a24);
  font-size: 28rpx;
  line-height: 1;
}

.label-code-input-shell {
  flex: 1;
  min-height: 72rpx;
  display: flex;
  align-items: center;
  border: 1px solid var(--color-border);
  border-radius: 16rpx;
  background: #fff;
  transition: border-color 0.2s ease, box-shadow 0.2s ease;
}

.label-code-input-shell.is-error {
  border-color: var(--color-danger, #ee0a24);
  box-shadow: 0 0 0 2rpx rgba(238, 10, 36, 0.08);
}

.label-code-prefix {
  flex-shrink: 0;
  padding: 0 16rpx 0 20rpx;
  font-size: 28rpx;
  line-height: 1;
  font-weight: 600;
  color: var(--color-text-primary);
}

.label-code-input {
  flex: 1;
  min-width: 0;
  height: 72rpx;
  font-size: 26rpx;
  color: var(--color-text-primary);
}

.label-code-preview,
.label-code-helper,
.label-code-notice,
.label-code-error {
  margin-top: 12rpx;
  margin-left: 184rpx;
  font-size: 24rpx;
  line-height: 1.5;
}

.label-code-preview,
.label-code-helper {
  color: var(--color-text-secondary);
}

.label-code-notice {
  color: #B45309;
}

.label-code-error {
  color: var(--color-danger, #ee0a24);
}

.material-add-panel {
  animation: panelFadeIn 0.2s ease-out;
  transform-origin: top center;
}

@keyframes panelFadeIn {
  from {
    opacity: 0;
    transform: translateY(10rpx);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

/* 建议框 */
.suggestion-box {
  position: absolute;
  top: 90px;
  left: 16px;
  right: 16px;
  z-index: 999;
  background: #fff;
  border-radius: var(--radius-lg);
  box-shadow: var(--shadow-lg);
  overflow: hidden;
  max-height: 300px;
  display: flex;
  flex-direction: column;
  animation: fadeIn 0.2s ease-out;
}

@keyframes fadeIn {
  from { opacity: 0; transform: translateY(-10px); }
  to { opacity: 1; transform: translateY(0); }
}

.suggestion-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 10px 16px;
  background-color: var(--color-bg-page);
  border-bottom: 1px solid var(--color-border);
  font-size: 12px;
  color: var(--color-text-secondary);
}

.suggestion-list {
  overflow-y: auto;
}

.suggestion-item {
  display: flex;
  align-items: center;
  padding: 12px 16px;
  background-color: #fff;
  transition: background-color 0.2s;
}

.suggestion-item:active {
  background-color: var(--color-bg-page);
}

.category-tag-pill {
  font-size: 10px;
  color: var(--color-brand);
  background: var(--color-brand-light);
  padding: 2px 6px;
  border-radius: var(--radius-sm);
}

/* 产品代码前缀 */
.product-code-field .van-field__body {
  display: flex !important;
  align-items: center;
}

.product-code-field .van-field__body::before {
  margin-right: 0px;
  font-size: 14px;
  color: var(--color-text-primary);
  font-weight: 400;
  line-height: 24px;
}

.product-code-field.chemical .van-field__body::before { content: "J-"; }
.product-code-field.film .van-field__body::before { content: "M-"; }

/* 标签加粗 */
.field-label-bold {
  font-weight: 600 !important;
  color: var(--color-text-primary) !important;
}

/* 成功弹窗 */
.success-dialog-body { background: #fff; overflow: hidden; }
.text-gray-dark { color: #646566 !important; }
.bg-gray-light { background: var(--color-bg-page) !important; }
.border-none { border: none !important; }
.box-shadow-blue { box-shadow: var(--shadow-brand); }

/* 灰色文字 */
.text-gray-400 { color: var(--color-text-secondary); }
.text-primary { color: var(--color-brand); }
.text-dark { color: var(--color-text-primary); }

.zone-manage-entry {
  display: flex;
  justify-content: flex-end;
  padding: 8px 16px 12px;
}

.zone-manage-link {
  font-size: 24rpx;
  line-height: 1.4;
  color: var(--color-brand);
}

.request-subcategory-hint {
  padding: 0 16px 12px;
  font-size: 24rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.field-governed-hint {
  padding: 0 32rpx 16rpx 32rpx;
  font-size: 22rpx;
  line-height: 1.5;
  color: var(--color-text-secondary);
}

.validity-switch-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 88rpx;
  padding: 0 32rpx;
}

.validity-switch-label {
  font-size: 28rpx;
  color: var(--color-text-primary);
}
