<view class="container label-page">
  <view wx:if="{{ loading && !hasLoadedOnce }}" class="page-loading-state">
    <van-loading type="spinner" vertical>加载中...</van-loading>
  </view>

  <block wx:elif="{{ list.length > 0 }}">
    <view
      wx:for="{{ list }}"
      wx:key="_id"
      class="label-row"
      bindtap="goToDetail"
      data-id="{{ item._id }}"
    >
      <view class="label-main">
        <text class="label-code">{{ item.unique_code }}</text>
        <view wx:if="{{ item.expiryBadgeText }}" class="label-badge">{{ item.expiryBadgeText }}</view>
      </view>
      <text class="label-qty {{ item.rowTone === 'warning' ? 'is-warning' : '' }}">{{ item._qtyStr }}</text>
      <text class="label-location">{{ item.location }}</text>
    </view>
  </block>

  <van-empty wx:elif="{{ hasLoadedOnce }}" description="暂无在库标签" />

  <view wx:if="{{ loading && hasLoadedOnce }}" class="inline-refresh-state">
    <van-loading size="20px">刷新中...</van-loading>
  </view>
  <view wx:if="{{ isEnd && list.length > 0 }}" class="list-end-state">
    已无更多
  </view>
</view>
