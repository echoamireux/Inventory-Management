<!-- 统一批次卡片组件 - 用于批次选择弹窗和库存详情页 -->
<view class="batch-card {{ item.isExpiring ? 'batch-card-expiring' : '' }}" hover-class="batch-card-hover" bindtap="onTap">
  <!-- 第一行：批号语义 + 数量 -->
  <view class="batch-card-row">
    <view class="batch-head-left">
      <view class="batch-code-row">
        <material-tag type="brand" text="{{ display.batchLabel }}" />
        <view class="batch-code">{{ display.batchValue }}</view>
        <view wx:if="{{ item.isExpiring }}" class="badge-expiry">{{ item.category === 'chemical' ? '临期' : '即将过期' }}</view>
        <view wx:if="{{ item.isArchived }}" class="badge-archived">已归档停用</view>
      </view>
    </view>
    <view class="batch-qty-wrap">
      <view class="batch-qty {{ item.isExpiring ? 'warning' : '' }}">
        <!-- 兼容多种数据格式 -->
        <block wx:if="{{ item._qtyStr }}">{{ item._qtyStr }}</block>
        <block wx:elif="{{ item.totalQuantity !== undefined }}">{{ item.totalQuantity }}<text class="batch-qty-unit">{{ item.unit }}</text></block>
        <block wx:else>{{ item.quantity.val }}<text class="batch-qty-unit">{{ item.quantity.unit }}</text></block>
      </view>
    </view>
  </view>

  <!-- 第二行：名称 + 子类别 -->
  <view class="batch-name-row">
    <view class="batch-name">{{ display.materialName }}</view>
    <material-tag
      wx:if="{{ display.subcategoryLabel }}"
      type="subcategory"
      text="{{ display.subcategoryLabel }}"
    />
  </view>

  <!-- 第三行：辅助信息 -->
  <view class="batch-meta-row">
    <view class="batch-meta-group">
      <material-tag type="meta" text="有效期" />
      <text class="batch-meta-value">{{ display.expiryLabel }}</text>
    </view>
    <view class="batch-meta-group batch-meta-group-location">
      <material-tag type="meta" text="库位" />
      <text class="batch-meta-value">{{ display.locationLabel }}</text>
    </view>
  </view>
</view>
