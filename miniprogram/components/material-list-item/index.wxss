/* material-list-item 组件 - 使用全局样式 */
.material-card-hover {
  background: #F9FAFB;
}

.material-subtitle-row {
  display: flex;
  align-items: center;
  gap: 6px;
  flex-wrap: wrap;
  margin-bottom: 6px;
}

.material-name {
  display: flex;
  align-items: center;
  min-height: 24px;
  margin-bottom: 0;
  line-height: 1.35;
}

.material-match-reason {
  margin: -2px 0 8px;
  font-size: 11px;
  line-height: 1.4;
  color: #9CA3AF;
}
